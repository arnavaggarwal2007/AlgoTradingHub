{
    "strategy": "iron_condor_income",
    "version": "1.0",
    
    "watchlist": ["SPY", "QQQ", "IWM"],
    
    "condor_rules": {
        "put_delta": 0.12,
        "call_delta": 0.12,
        "delta_tolerance": 0.03,
        "wing_width": 5,
        "min_dte": 30,
        "max_dte": 45,
        "min_total_credit_ratio": 0.33,
        "profit_target_pct": 0.50,
        "stop_loss_multiplier": 2.0,
        "time_exit_dte": 21,
        "side_breach_delta": 0.40
    },
    
    "iv_rules": {
        "min_iv_rank": 30,
        "optimal_iv_rank": 50,
        "skip_below_vix": 12,
        "skip_above_vix": 35
    },
    
    "risk": {
        "max_concurrent_condors": 5,
        "max_risk_per_condor_pct": 0.05,
        "max_portfolio_exposure_pct": 0.20,
        "max_same_underlying": 2
    },

    "earnings_dates_manual": {},
    
    "execution": {
        "use_mid_price": true,
        "mid_price_increment": 0.01,
        "mid_price_max_retries": 10,
        "scan_interval_minutes": 5
    },

    "logging": {
        "level": "INFO",
        "log_dir": "logs"
    }
}
